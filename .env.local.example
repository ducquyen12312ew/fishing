# Vercel Postgres connection strings
# Get from: Vercel Dashboard → Storage → Postgres → Quickstart tab
# Copy all these values from there

POSTGRES_URL="postgres://user:password@host:5432/database?sslmode=require"
POSTGRES_PRISMA_URL="postgres://user:password@host:5432/database?schema=prisma"
POSTGRES_URL_NO_SSL="postgres://user:password@host:5432/database"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/database"
POSTGRES_USER="postgres"
POSTGRES_HOST="ep-xxx.region.neon.tech"
POSTGRES_PASSWORD="your_password"
POSTGRES_DATABASE="neondb"
